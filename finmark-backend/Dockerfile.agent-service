FROM node:20-alpine

WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY services/data-service/package.json ./services/data-service/
COPY services/llm-gateway/package.json ./services/llm-gateway/
COPY services/agent-service/package.json ./services/agent-service/

RUN corepack enable && corepack prepare pnpm@9 --activate

RUN pnpm install --frozen-lockfile --prod

COPY services/agent-service ./services/agent-service
COPY services/llm-gateway ./services/llm-gateway

WORKDIR /app/services/agent-service
RUN pnpm build

EXPOSE 3003

CMD ["node", "dist/index.js"]
